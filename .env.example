# =============================================
# IMA Backend - Variables de Entorno
# =============================================
# Copia este archivo como .env y ajusta los valores
# cp .env.example .env

# ---- Entorno ----
ENVIRONMENT=production
DEBUG=false

# ---- API ----
API_PREFIX=/api/v1

# ---- Seguridad ----
# IMPORTANTE: Cambiar en producción
API_KEY=cambiar-esta-clave-en-produccion

# ---- CORS ----
# Separar múltiples orígenes con coma
ALLOWED_ORIGINS=https://ima.up.railway.app

# ---- Modelos ----
MODEL_PATH=models/lstm_latest.pt
SCALER_PATH=models/scaler.pkl
METADATA_PATH=models/lstm_metadata.json
MODEL_BACKEND=local

# ---- Parámetros del modelo ----
LOOKBACK=24
HORIZON=1
MAX_FORECAST_HORIZON=24
PREDICTION_TIMEOUT=5.0

# ---- Umbrales meteorológicos ----
RH_HIGH=90.0
RH_MEDIUM=85.0
TEMP_DROP_2H=-0.5
WIND_CALM_MS=1.0
PRECIP_EVENT_MMHR=0.5

# ---- Logging ----
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE=reports/api.log

# ---- Métricas ----
ENABLE_METRICS=true
METRICS_NAMESPACE=PrecipitationAPI
